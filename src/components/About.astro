---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  id: string;
  title: string;
  subtitle: string;
  paragraphs: string[];
  image?: ImageMetadata;
  imageAlt?: string;
  alt?: boolean;
}

const { id, title, subtitle, paragraphs, image, imageAlt = '', alt = false } = Astro.props;
---

<section id={id} class:list={['section', { 'section--alt': alt }]}>
  <div class="container">
    <h2 class="section__title">{title}</h2>
    <p class="section__subtitle">{subtitle}</p>
    {image ? (
      <div class="about__grid">
        <div class="about__text">
          {paragraphs.map(p => <p>{p}</p>)}
        </div>
        <div class="about__image-wrapper">
          <Image
            src={image}
            alt={imageAlt}
            widths={[400, 600, 800]}
            sizes="(min-width: 768px) 50vw, 100vw"
            loading="lazy"
          />
        </div>
      </div>
    ) : (
      <div class="about__statement">
        {paragraphs.map(p => <p>{p}</p>)}
      </div>
    )}
  </div>
</section>
