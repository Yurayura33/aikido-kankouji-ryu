---
interface Props {
  contact: {
    title: string;
    subtitle: string;
    intro?: string;
    phoneLabel: string;
    phone: string;
    phoneHref: string;
    emailLabel: string;
    email: string;
    emailHref: string;
    areaLabel: string;
    area: string;
    mapsLabel: string;
    mapsUrl: string;
    mapEmbedUrl?: string;
  };
  alt?: boolean;
}

const { contact, alt = false } = Astro.props;
---

<section id="contact" class:list={['section', { 'section--alt': alt }]}>
  <div class="container">
    <h2 class="section__title">{contact.title}</h2>
    <p class="section__subtitle">{contact.subtitle}</p>
    {contact.intro && <p class="contact__intro">{contact.intro}</p>}
    <div class="contact__grid contact__grid--therapy">
      <div class="contact__item">
        <svg class="contact__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <p class="contact__label">{contact.phoneLabel}</p>
        <p class="contact__value">
          <a href={contact.phoneHref}>{contact.phone}</a>
        </p>
      </div>
      <div class="contact__item">
        <svg class="contact__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        <p class="contact__label">{contact.emailLabel}</p>
        <p class="contact__value">
          <a href={contact.emailHref}>{contact.email}</a>
        </p>
      </div>
      <div class="contact__item">
        <svg class="contact__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <p class="contact__label">{contact.areaLabel}</p>
        <p class="contact__value">{contact.area}</p>
        <p class="contact__value">
          <a href={contact.mapsUrl} target="_blank" rel="noopener noreferrer" class="contact__link-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            {contact.mapsLabel}
          </a>
        </p>
      </div>
    </div>
    {contact.mapEmbedUrl && (
      <div class="contact__map">
        <iframe
          src={contact.mapEmbedUrl}
          width="600"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Japanese Wellness Therapy location"
        ></iframe>
      </div>
    )}
  </div>
</section>
