---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  titleJp: string;
  titleEn: string;
  tagline: string;
  cta: string;
  ctaHref: string;
  image: ImageMetadata;
  imageAlt: string;
  scrollLabel?: string;
  scrollHref?: string;
  eager?: boolean;
}

const {
  titleJp,
  titleEn,
  tagline,
  cta,
  ctaHref,
  image,
  imageAlt,
  scrollLabel,
  scrollHref,
  eager = true,
} = Astro.props;
---

<section class="hero">
  <Image
    src={image}
    alt={imageAlt}
    class="hero__image"
    widths={[600, 900, 1200, 1800]}
    sizes="100vw"
    loading={eager ? 'eager' : 'lazy'}
  />
  <div class="hero__content">
    <h1 class="hero__title-jp">{titleJp}</h1>
    <p class="hero__title-en">{titleEn}</p>
    <p class="hero__tagline">{tagline}</p>
    <a href={ctaHref} class="hero__cta">{cta}</a>
  </div>
  {scrollHref && (
    <a href={scrollHref} class="hero__scroll" aria-label={scrollLabel}>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 5v14M19 12l-7 7-7-7"/>
      </svg>
    </a>
  )}
</section>
