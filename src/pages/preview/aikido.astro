---
// Hidden preview of the Aikido page in its multi-page form. Promote to /aikido.astro once signed off.
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/About.astro';
import Instructor from '../../components/Instructor.astro';
import FirstVisit from '../../components/FirstVisit.astro';
import ImageBand from '../../components/ImageBand.astro';
import Videos from '../../components/Videos.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import { aikido } from '../../data/aikido';

import heroImage from '../../assets/image7.jpeg';
import aboutImage from '../../assets/image2.jpeg';
import instructorImage from '../../assets/image1.jpeg';
import img3 from '../../assets/image3.jpeg';
import img4 from '../../assets/image4.jpeg';
import img5 from '../../assets/image5.jpeg';
import img6 from '../../assets/image6.jpeg';

const navLinks = [
  { href: '#about', label: aikido.nav.about },
  { href: '#instructor', label: aikido.nav.instructor },
  { href: '#first-visit', label: aikido.nav.firstVisit },
  { href: '#videos', label: aikido.nav.videos },
  { href: '#contact', label: aikido.nav.contact },
  { href: '/preview/therapy', label: 'Therapy' },
];
---

<Layout
  title={aikido.meta.title}
  description={aikido.meta.description}
  schema={aikido.schema}
  noindex
>
  <Header brand="Aikido Kankouji-ryu" brandHref="/preview" links={navLinks} />
  <main id="main">
    <Hero
      titleJp={aikido.hero.titleJp}
      titleEn={aikido.hero.titleEn}
      tagline={aikido.hero.tagline}
      cta={aikido.hero.cta}
      ctaHref="#contact"
      image={heroImage}
      imageAlt="Aikido training session at Kankouji-ryu dojo"
      scrollLabel={aikido.hero.scroll}
      scrollHref="#about"
    />
    <About
      id="about"
      title={aikido.about.title}
      subtitle={aikido.about.subtitle}
      paragraphs={[aikido.about.p1, aikido.about.p2, aikido.about.p3]}
      image={aboutImage}
      imageAlt="Aikido technique demonstration at Kankouji-ryu dojo"
      alt
    />
    <Instructor
      id="instructor"
      title={aikido.instructor.title}
      subtitle={aikido.instructor.subtitle}
      name={aikido.instructor.name}
      rank={aikido.instructor.rank}
      bios={[aikido.instructor.bio1, aikido.instructor.bio2]}
      image={instructorImage}
      imageAlt="Joseph Eiko, 7th Dan Shihan of Kankouji-ryu"
    />
    <FirstVisit
      id="first-visit"
      title={aikido.firstVisit.title}
      subtitle={aikido.firstVisit.subtitle}
      intro={aikido.firstVisit.intro}
      items={aikido.firstVisit.items}
      pricing={aikido.firstVisit.pricing}
      alt
    />
    <ImageBand images={[img5, img6, img3, img4]} />
    <Videos />
    <Contact />
  </main>
  <Footer backToTop={aikido.footer.backToTop} />
</Layout>
