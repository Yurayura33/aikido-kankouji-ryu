---
// Hidden preview of the new brand hub. Promote to /index.astro once signed off.
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { home } from '../../data/home';

import aikidoImg from '../../assets/image7.jpeg';
import therapyImg from '../../assets/therapy/image4.jpeg';

const cardImages = {
  aikido: aikidoImg,
  therapy: therapyImg,
};

const navLinks = [
  { href: '/preview/therapy', label: 'Therapy' },
  { href: '/preview/aikido', label: 'Aikido' },
];
---

<Layout
  title={home.meta.title}
  description={home.meta.description}
  schema={home.schema}
  noindex
>
  <Header brand={home.intro.titleEn} brandHref="/preview" links={navLinks} />
  <main id="main">
    <section class="hub-hero">
      <span class="hub-hero__kanji" aria-hidden="true">{home.intro.titleJp}</span>
      <div class="container hub-hero__inner">
        <h1 class="hub-hero__title">{home.intro.titleEn}</h1>
        <p class="hub-hero__tagline">{home.intro.tagline}</p>
      </div>
    </section>
    <section class="section">
      <div class="container">
        <div class="hub__services">
          {home.services.map(s => (
            <a class:list={['service-card', `service-card--${s.key}`]} href={`/preview${s.href}`}>
              <div class="service-card__image">
                <Image
                  src={cardImages[s.key]}
                  alt={s.name}
                  widths={[400, 600, 800, 1000]}
                  sizes="(min-width: 768px) 50vw, 100vw"
                  loading="eager"
                />
              </div>
              <div class="service-card__body">
                <p class="service-card__jp">{s.jp}</p>
                <h2 class="service-card__name">{s.name}</h2>
                <p class="service-card__blurb">{s.blurb}</p>
                <span class="service-card__cta">{s.cta} →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer backToTop={home.footer.backToTop} instagram="https://www.instagram.com/joseph_koken" />
</Layout>
