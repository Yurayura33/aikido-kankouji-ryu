---
// Hidden preview of the new Therapy page. Promote to /therapy.astro once signed off.
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/About.astro';
import FirstVisit from '../../components/FirstVisit.astro';
import Instructor from '../../components/Instructor.astro';
import Pricing from '../../components/Pricing.astro';
import ImageBand from '../../components/ImageBand.astro';
import ContactTherapy from '../../components/ContactTherapy.astro';
import Footer from '../../components/Footer.astro';
import { therapy } from '../../data/therapy';

import heroImage from '../../assets/therapy/image4.jpeg';
import practitionerImage from '../../assets/therapy/image1.jpeg';
import gal2 from '../../assets/therapy/image2.jpeg';
import gal3 from '../../assets/therapy/image3.jpeg';
import gal5 from '../../assets/therapy/image5.jpeg';
import gal6 from '../../assets/therapy/image6.jpeg';

const navLinks = [...therapy.nav, { href: '/preview/aikido', label: 'Aikido' }];
---

<Layout
  title={therapy.meta.title}
  description={therapy.meta.description}
  schema={therapy.schema}
  ogImage="og-therapy.jpg"
  theme="therapy"
  noindex
>
  <Header brand="Japanese Wellness Therapy" brandHref="/preview" links={navLinks} />
  <main id="main">
    <Hero
      titleJp={therapy.hero.titleJp}
      titleEn={therapy.hero.titleEn}
      tagline={therapy.hero.tagline}
      cta={therapy.hero.cta}
      ctaHref="#contact"
      image={heroImage}
      imageAlt="Japanese wellness therapy treatment session"
      scrollLabel={therapy.hero.scroll}
      scrollHref="#treatment"
    />
    <About
      id="treatment"
      title={therapy.intro.title}
      subtitle={therapy.intro.subtitle}
      paragraphs={therapy.intro.paragraphs}
      alt
    />
    <FirstVisit
      id="methods"
      title={therapy.methods.title}
      subtitle={therapy.methods.subtitle}
      intro={therapy.methods.intro}
      items={therapy.methods.items}
      note={therapy.methods.note}
    />
    <Instructor
      id="practitioner"
      title={therapy.practitioner.title}
      subtitle={therapy.practitioner.subtitle}
      name={therapy.practitioner.name}
      rank={therapy.practitioner.rank}
      bios={[therapy.practitioner.bio1, therapy.practitioner.bio2]}
      image={practitionerImage}
      imageAlt="Joseph, Japanese wellness therapy practitioner"
      alt
    />
    <Pricing
      id="pricing"
      title={therapy.pricing.title}
      subtitle={therapy.pricing.subtitle}
      items={therapy.pricing.items}
      note={therapy.pricing.note}
      homeVisit={therapy.pricing.homeVisit}
    />
    <ImageBand images={[gal5, gal6, gal3, gal2]} />
    <ContactTherapy contact={therapy.contact} alt />
  </main>
  <Footer backToTop={therapy.footer.backToTop} instagram="https://www.instagram.com/joseph_koken" />
</Layout>
